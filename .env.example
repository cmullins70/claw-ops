# Claw Ops Phase 1 — required env vars
# Copy to deploy/.env and fill in before running docker compose.

# Required: shared secret for webhook auth (must not be 'replace-me')
CLAW_OPS_SHARED_SECRET=

# Grafana admin password (default: change-me)
GRAFANA_ADMIN_PASSWORD=

# Optional overrides
# LOG_LEVEL=info
# CLAW_OPS_PORT=8787
